# =========================
# Frontend env.example (CRA / React)
# =========================
# Copy to: frontend/.env.local (recommended) or frontend/.env
# For docker-compose: you can ALSO put these variables into the project-root ".env"
# (docker-compose automatically reads root .env for ${VAR} substitution in docker-compose.yml).
#
# Only variables prefixed with REACT_APP_ are embedded into the bundle.

# Backend base URL (NO /api suffix; frontend services add it)
REACT_APP_API_URL=http://localhost:3000

# Socket.IO base URL
REACT_APP_WS_URL=ws://localhost:3000

# --- Docker dev conveniences (optional) ---
# CHOKIDAR_USEPOLLING=true
# WDS_SOCKET_PORT=3001

