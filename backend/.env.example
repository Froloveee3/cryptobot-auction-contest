# =========================
# Backend env.example
# =========================
# Copy to (for local backend runs): backend/.env.local (recommended) or backend/.env
# For docker-compose: you can ALSO put these variables into the project-root ".env"
# (docker-compose автоматически читает root .env для подстановки ${VAR} в docker-compose.yml).
#
# NOTE: in this repo we load env files from project root, but Nest ConfigModule is set to:
#   envFilePath: ['.env.<NODE_ENV>.local', '.env.<NODE_ENV>', '.env.local', '.env']
# so for backend-in-docker you usually set variables in docker-compose.yml.

# --- Runtime ---
NODE_ENV=development
PORT=3000
API_PREFIX=api

# --- CORS ---
# "*"                     => allow all (dev-friendly)
# "http://localhost:3001" => allowlist (comma-separated for multiple)
# "false"                 => disable CORS
CORS_ORIGIN=*

# --- MongoDB (required) ---
# Local backend (running on host) connects to localhost published port.
MONGODB_URI=mongodb://admin:password@localhost:27017/auction_db?authSource=admin&replicaSet=rs0

# --- Redis (shared client) ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0

# --- BullMQ / Queue Redis (optional override) ---
# If not set, falls back to REDIS_*.
QUEUE_REDIS_HOST=
QUEUE_REDIS_PORT=
QUEUE_REDIS_PASSWORD=
QUEUE_REDIS_DB=1

# --- Auth (Website JWT) ---
# In NODE_ENV=production you MUST set a real secret (backend will fail-fast otherwise).
JWT_SECRET=
JWT_EXPIRES_IN_SEC=3600

# STRICT MODE (recommended)
# false => ONLY JWT / Telegram initData auth is accepted
ALLOW_INSECURE_QUERY_USERID=false

# --- Admin bootstrap (optional; useful for demo) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminadmin

# --- Telegram WebView auth (planned) ---
TELEGRAM_BOT_TOKEN=

# --- Rate limiting (Redis-backed) ---
RATE_LIMIT_DISABLED=false
RATE_LIMIT_MULTIPLIER=1

# --- Scripts (optional) ---
# Used only by backend/src/scripts/*.js
SMOKE_BASE_URL=http://localhost:3000/api

