# =========================
# Root env.example (for docker-compose)
# =========================
# Copy to: ./.env
#
# docker-compose automatically reads ./.env (same directory as docker-compose.yml)
# and uses it for ${VAR} substitution.
#
# This file is meant for Docker-only workflow.

# --- Global runtime ---
NODE_ENV=development
API_PREFIX=api

# --- Ports (host-side) ---
BACKEND_PORT=3000
FRONTEND_PORT=3001

# --- CORS ---
# "*"                     => allow all (dev-friendly)
# "http://localhost:3001" => allowlist (comma-separated)
# "false"                 => disable CORS
CORS_ORIGIN=

# Used only by backend-perf service (profile perf)
CORS_ORIGIN_PERF=http://localhost:3001

# --- MongoDB root user (used by mongodb + mongodb-init) ---
MONGO_INITDB_ROOT_USERNAME=admin
MONGO_INITDB_ROOT_PASSWORD=password
MONGO_INITDB_DATABASE=auction_db

# Replica set member host
# - docker-only default: mongodb:27017
# - hybrid (backend local) uses mongodb-init-host and localhost:27017
MONGO_RS_HOST=mongodb:27017

# --- MongoDB URIs (docker vs host) ---
# docker-compose uses *_DOCKER variables; local backend uses MONGODB_URI (or MONGODB_URI_HOST).
MONGODB_URI_DOCKER=mongodb://admin:password@mongodb:27017/auction_db?authSource=admin&replicaSet=rs0
MONGODB_URI_HOST=mongodb://admin:password@localhost:27017/auction_db?authSource=admin&replicaSet=rs0
# Backward compatible var used by backend code (required):
MONGODB_URI=mongodb://admin:password@localhost:27017/auction_db?authSource=admin&replicaSet=rs0

# --- Redis (docker vs host) ---
REDIS_HOST_DOCKER=redis
REDIS_HOST_HOST=localhost
# Backward compatible var used by backend code:
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis_password
REDIS_DB=0

# --- BullMQ Redis override (optional) ---
# If empty, backend falls back to REDIS_*.
QUEUE_REDIS_HOST_DOCKER=
QUEUE_REDIS_PORT_DOCKER=
QUEUE_REDIS_PASSWORD_DOCKER=
QUEUE_REDIS_DB_DOCKER=1

# --- Auth / JWT ---
# Dev secret (OK for local demo; change if ever exposed)
JWT_SECRET=
JWT_EXPIRES_IN_SEC=3600

# Perf profile JWT secret (backend-perf)
JWT_SECRET_PERF=

# Strict mode (recommended): do NOT accept ?userId=
ALLOW_INSECURE_QUERY_USERID=false

# --- Admin bootstrap (for demo/admin-only endpoints like /bots, /admin/audit) ---
ADMIN_USERNAME=admin
ADMIN_PASSWORD=adminadmin

# --- Telegram WebView (planned) ---
TELEGRAM_BOT_TOKEN=

# --- Rate limiting ---
RATE_LIMIT_DISABLED=false
RATE_LIMIT_MULTIPLIER=1

# --- Frontend (CRA) ---
# Backend base URL (NO /api suffix)
REACT_APP_API_URL=
REACT_APP_WS_URL=

# --- Dev convenience (optional) ---
CHOKIDAR_USEPOLLING=true

# CRA dev-server HMR behind HTTPS reverse proxy (nginx).
WDS_SOCKET_HOST=cryptobot-auction-contest.ru
WDS_SOCKET_PORT=443
WDS_SOCKET_PATH=/ws
WDS_SOCKET_PROTOCOL=wss

# --- Scripts (optional) ---
SMOKE_BASE_URL=http://localhost:3000/api

